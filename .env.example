# Supabase — copia este archivo a .env.local y rellena con tus claves.
# (.env.local NO se sube a git; .env.example sí, como plantilla: SIN claves reales.)

# Públicas (las usa el navegador y el servidor).
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_TU-CLAVE

# SOLO servidor. NUNCA le pongas el prefijo NEXT_PUBLIC ni la subas a git.
# La usa la creación de cuentas de meseras (auth.admin.createUser).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_TU-CLAVE
